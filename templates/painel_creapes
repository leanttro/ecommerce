<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Produtora | {{ loja.nome }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #111; color: #eee; }
        .modal { transition: opacity 0.25s ease; }
        body.modal-active { overflow-x: hidden; overflow-y: visible !important; }
        .list-group-item { cursor: move; }
        .list-group-item.sortable-ghost { opacity: 0.4; background-color: #222; border: 2px dashed #444; }
        
        .mobile-nav-hidden { display: none; }
        .mobile-nav-visible { display: block; animation: slideDown 0.3s ease-out; }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-black font-sans leading-normal tracking-normal text-gray-200">

    {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
            <div class="fixed top-4 right-4 z-50 flex flex-col gap-2" id="flash-messages-container">
            {% for category, message in messages %}
                <div class="{% if category == 'error' %}bg-red-600{% else %}bg-green-600{% endif %} text-white px-6 py-4 rounded shadow-lg flex items-center gap-2 animate-bounce flash-message-item">
                    <i data-lucide="{% if category == 'error' %}alert-circle{% else %}check-circle{% endif %}"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}
            </div>
        {% endif %}
    {% endwith %}

    <nav class="bg-neutral-900 shadow-sm fixed w-full z-10 top-0 border-b border-neutral-800">
        <div class="w-full container mx-auto flex flex-wrap items-center justify-between mt-0 py-4 px-6">
            <div class="flex items-center">
                <span class="text-white text-xl font-bold flex items-center gap-2">
                    <i data-lucide="film" class="text-yellow-400"></i> Painel Produtora: {{ loja.nome }}
                </span>
            </div>
            <div class="flex items-center gap-4">
                <a href="https://catalogo.leanttro.com/{{ loja.slug_url }}/" target="_blank" class="text-gray-400 hover:text-yellow-400 flex items-center gap-1 text-sm font-bold">
                    <i data-lucide="external-link" class="w-4 h-4"></i> Ver Site
                </a>
                <a href="/logout" class="text-red-500 hover:text-red-400 flex items-center gap-1 text-sm font-bold">
                    <i data-lucide="log-out" class="w-4 h-4"></i> Sair
                </a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto mt-24 px-6 md:px-0 flex flex-col md:flex-row gap-6">
        
        <aside class="w-full md:w-64 bg-neutral-900 rounded-lg shadow-sm border border-neutral-800 p-4 h-fit sticky top-24">
            <button onclick="toggleMobileMenu()" class="md:hidden w-full flex items-center justify-between bg-neutral-800 p-3 rounded-lg border border-neutral-700 text-white font-bold hover:bg-neutral-700 transition-colors mb-2">
                <span class="flex items-center gap-2"><i data-lucide="menu"></i> Menu Principal</span>
                <i data-lucide="chevron-down" id="menuChevron" class="transition-transform duration-300"></i>
            </button>

            <nav id="sidebarNav" class="space-y-2 hidden md:block">
                <a href="#categorias" class="flex items-center gap-2 px-4 py-3 text-gray-300 hover:bg-neutral-800 hover:text-yellow-400 rounded-lg transition-colors font-bold" onclick="selectMenuItem('categorias')">
                    <i data-lucide="layers"></i> Seções (Categorias)
                </a>
                <a href="#produtos" class="flex items-center gap-2 px-4 py-3 text-gray-300 hover:bg-neutral-800 hover:text-yellow-400 rounded-lg transition-colors font-bold" onclick="selectMenuItem('produtos')">
                    <i data-lucide="video"></i> Vídeos / Projetos
                </a>
                <a href="#blog" class="flex items-center gap-2 px-4 py-3 text-gray-300 hover:bg-neutral-800 hover:text-yellow-400 rounded-lg transition-colors font-bold" onclick="selectMenuItem('blog')">
                    <i data-lucide="briefcase"></i> Serviços (Capabilities)
                </a>
                <a href="#sobre" class="flex items-center gap-2 px-4 py-3 text-gray-300 hover:bg-neutral-800 hover:text-yellow-400 rounded-lg transition-colors font-bold" onclick="selectMenuItem('sobre')">
                    <i data-lucide="users"></i> Sobre a Produtora
                </a>
                <a href="#config" class="flex items-center gap-2 px-4 py-3 text-gray-300 hover:bg-neutral-800 hover:text-yellow-400 rounded-lg transition-colors font-bold" onclick="selectMenuItem('config')">
                    <i data-lucide="settings"></i> Configurações Base
                </a>
            </nav>
        </aside>

        <main class="flex-1 space-y-6">

            <section id="categorias" class="bg-neutral-900 rounded-lg shadow-sm border border-neutral-800 p-6">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4 md:gap-0">
                    <div>
                        <h2 class="text-2xl font-bold text-white flex items-center gap-2"><i data-lucide="layers" class="text-yellow-400"></i> Seções do Site</h2>
                        <p class="text-sm text-gray-400 mt-1">Crie as categorias 'Hero' e 'Portfolio' para organizar onde os vídeos aparecem.</p>
                    </div>
                    <button onclick="novaCategoria()" class="bg-yellow-500 hover:bg-yellow-600 text-black font-bold py-2 px-3 md:px-4 rounded flex items-center gap-2 text-xs md:text-sm">
                        <i data-lucide="plus"></i> Nova Seção
                    </button>
                </div>
                
                <div class="bg-neutral-800 rounded-lg border border-neutral-700">
                    <ul id="lista-categorias" class="divide-y divide-neutral-700">
                        {% for cat in categorias %}
                        <li class="list-group-item flex items-center justify-between p-4 hover:bg-neutral-700 transition-colors" data-id="{{ cat.id }}">
                             <div class="flex items-center gap-3">
                                <i data-lucide="grip-vertical" class="text-gray-500 cursor-move"></i>
                                <span class="font-bold text-white">{{ cat.nome }} <span class="text-xs text-gray-400 ml-2 font-normal">(slug: {{ cat.slug }})</span></span>
                            </div>
                            <div class="flex items-center gap-2">
                                <button onclick='editarCategoria({{ cat | tojson }})' class="text-blue-400 hover:text-blue-300 p-2"><i data-lucide="edit-2" class="w-4 h-4"></i></button>
                                <a href="/{{ loja.slug_url }}/admin/categoria/excluir/{{ cat.id }}" class="text-red-500 hover:text-red-400 p-2" onclick="return confirm('Excluir esta categoria?')"><i data-lucide="trash-2" class="w-4 h-4"></i></a>
                            </div>
                        </li>
                        {% else %}
                        <li class="p-6 text-center text-gray-500">Nenhuma seção cadastrada.</li>
                        {% endfor %}
                    </ul>
                </div>
            </section>

            <section id="produtos" class="bg-neutral-900 rounded-lg shadow-sm border border-neutral-800 p-6 hidden">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-white flex items-center gap-2"><i data-lucide="video" class="text-yellow-400"></i> Vídeos / Projetos</h2>
                    <button onclick="novoProduto()" class="bg-yellow-500 hover:bg-yellow-600 text-black font-bold py-2 px-4 rounded flex items-center gap-2 text-sm">
                        <i data-lucide="plus"></i> Novo Vídeo
                    </button>
                </div>

                <div class="overflow-x-auto bg-neutral-800 rounded-lg border border-neutral-700">
                    <table class="min-w-full divide-y divide-neutral-700">
                        <thead class="bg-neutral-900">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Nome</th>
                                <th class="px-6 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Local/Estilo</th>
                                <th class="px-6 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Ano</th>
                                <th class="px-6 py-3 text-right text-xs font-bold text-gray-400 uppercase tracking-wider">Ações</th>
                            </tr>
                        </thead>
                        <tbody class="bg-neutral-800 divide-y divide-neutral-700">
                            {% for prod in produtos %}
                            <tr class="hover:bg-neutral-700 transition-colors">
                                <td class="px-6 py-4"><div class="text-sm font-bold text-white line-clamp-1">{{ prod.nome }}</div></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">{{ prod.descricao }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">{{ prod.estoque }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <button onclick='editarProduto({{ prod | tojson }})' class="text-blue-400 hover:text-blue-300 mr-3"><i data-lucide="edit-2" class="w-4 h-4"></i></button>
                                    <a href="/{{ loja.slug_url }}/admin/produto/excluir/{{ prod.id }}" class="text-red-500 hover:text-red-400" onclick="return confirm('Excluir este vídeo?')"><i data-lucide="trash-2" class="w-4 h-4"></i></a>
                                </td>
                            </tr>
                             {% else %}
                            <tr><td colspan="4" class="px-6 py-8 text-center text-gray-500">Nenhum vídeo cadastrado.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>

            <section id="blog" class="bg-neutral-900 rounded-lg shadow-sm border border-neutral-800 p-6 hidden">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-white flex items-center gap-2"><i data-lucide="briefcase" class="text-yellow-400"></i> Serviços</h2>
                    <button onclick="novoPost()" class="bg-yellow-500 hover:bg-yellow-600 text-black font-bold py-2 px-4 rounded flex items-center gap-2 text-sm">
                        <i data-lucide="plus"></i> Novo Serviço
                    </button>
                </div>
                <div class="bg-neutral-800 rounded-lg border border-neutral-700 divide-y divide-neutral-700">
                    {% for post in posts %}
                    <div class="p-4 flex justify-between items-center hover:bg-neutral-700 transition-colors">
                        <div>
                             <h3 class="font-bold text-white">{{ post.titulo }}</h3>
                        </div>
                        <div class="flex items-center gap-2">
                             <button onclick='editarPost({{ post | tojson }})' class="text-blue-400 hover:text-blue-300 p-2"><i data-lucide="edit-2" class="w-4 h-4"></i></button>
                            <a href="/{{ loja.slug_url }}/admin/post/excluir/{{ post.id }}" class="text-red-500 hover:text-red-400 p-2" onclick="return confirm('Excluir este serviço?')"><i data-lucide="trash-2" class="w-4 h-4"></i></a>
                        </div>
                    </div>
                    {% else %}
                    <div class="p-6 text-center text-gray-500">Nenhum serviço cadastrado.</div>
                    {% endfor %}
                </div>
            </section>

            <form action="/{{ loja.slug_url }}/admin/painel" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="template_ativo" value="creapes">
                
                <section id="sobre" class="bg-neutral-900 rounded-lg shadow-sm border border-neutral-800 p-6 hidden space-y-6">
                    <h2 class="text-2xl font-bold text-white flex items-center gap-2 mb-6"><i data-lucide="users" class="text-yellow-400"></i> Sobre a Produtora</h2>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-bold mb-2 text-gray-300">Título da Seção</label>
                            <input type="text" name="sobre_titulo" value="{{ loja.sobre_titulo or '' }}" placeholder="Ex: We Are Creapes" class="w-full bg-neutral-800 border border-neutral-700 rounded p-2 text-white">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-bold mb-2 text-gray-300">Manifesto / Texto Principal</label>
                            <textarea name="sobre_texto" rows="4" class="w-full bg-neutral-800 border border-neutral-700 rounded p-2 text-white">{{ loja.sobre_texto or '' }}</textarea>
                        </div>

                        <div class="bg-neutral-800 p-4 rounded border border-neutral-700">
                            <label class="block text-sm font-bold mb-2 text-gray-300">Foto Diretor 1</label>
                            {% if loja.banner1_url %}
                            <img src="{{ loja.banner1_url }}" class="w-full h-32 object-cover rounded mb-2 border border-neutral-600">
                            {% endif %}
                            <input type="file" name="bannerprincipal1" accept="image/*" class="text-sm text-gray-400 w-full">
                        </div>
                        <div class="bg-neutral-800 p-4 rounded border border-neutral-700">
                            <label class="block text-sm font-bold mb-2 text-gray-300">Foto Diretor 2</label>
                            {% if loja.bannermenor1_url %}
                            <img src="{{ loja.bannermenor1_url }}" class="w-full h-32 object-cover rounded mb-2 border border-neutral-600">
                            {% endif %}
                            <input type="file" name="bannermenor1" accept="image/*" class="text-sm text-gray-400 w-full">
                        </div>
                        <div class="bg-neutral-800 p-4 rounded border border-neutral-700">
                            <label class="block text-sm font-bold mb-2 text-gray-300">Foto Diretor 3</label>
                            {% if loja.bannermenor2_url %}
                            <img src="{{ loja.bannermenor2_url }}" class="w-full h-32 object-cover rounded mb-2 border border-neutral-600">
                            {% endif %}
                            <input type="file" name="bannermenor2" accept="image/*" class="text-sm text-gray-400 w-full">
                        </div>
                    </div>
                </section>

                <section id="config" class="bg-neutral-900 rounded-lg shadow-sm border border-neutral-800 p-6 hidden space-y-6">
                     <h2 class="text-2xl font-bold text-white flex items-center gap-2 mb-6"><i data-lucide="settings" class="text-yellow-400"></i> Configurações Base</h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-300">Nome da Produtora</label>
                            <input type="text" name="nome" value="{{ loja.nome }}" class="w-full bg-neutral-800 border border-neutral-700 rounded p-2 text-white">
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-300">WhatsApp Comercial (Apenas números)</label>
                            <input type="text" name="whatsapp" value="{{ loja.whatsapp_comercial }}" class="w-full bg-neutral-800 border border-neutral-700 rounded p-2 text-white">
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-300">Link do Instagram</label>
                            <input type="text" name="instagram_url" value="{{ loja.instagram_url or '' }}" placeholder="https://instagram.com/suaempresa" class="w-full bg-neutral-800 border border-neutral-700 rounded p-2 text-white">
                        </div>
                         <div>
                            <label class="block text-sm font-bold mb-2 text-gray-300">Cor Principal (Accent)</label>
                            <input type="color" name="cor_primaria" value="{{ loja.cor_primaria }}" class="h-10 w-full p-0 border border-neutral-700 rounded cursor-pointer bg-neutral-800">
                        </div>
                    </div>

                    <div class="pt-4 border-t border-neutral-800">
                        <label class="block text-sm font-bold mb-2 text-gray-300">Nova Senha do Painel</label>
                        <input type="password" name="nova_senha" placeholder="Deixe em branco para manter a atual" class="w-full md:w-1/2 bg-neutral-800 border border-neutral-700 rounded p-2 text-white">
                    </div>
                </section>

                <div class="fixed bottom-0 left-0 w-full bg-neutral-900 border-t border-neutral-800 p-4 flex justify-end z-20">
                    <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-black font-bold py-3 px-8 rounded shadow-lg flex items-center gap-2">
                        <i data-lucide="save"></i> SALVAR ALTERAÇÕES
                    </button>
                </div>
            </form>
        </main>
    </div>

    <div id="categoriaModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
        <div class="modal-overlay absolute w-full h-full bg-black opacity-80"></div>
        <div class="modal-container bg-neutral-900 border border-neutral-700 w-11/12 md:max-w-md mx-auto rounded shadow-lg z-50 overflow-y-auto">
            <div class="modal-content py-4 text-left px-6">
                <div class="flex justify-between items-center pb-3 border-b border-neutral-800">
                    <p class="text-2xl font-bold text-white" id="catModalTitle">Nova Seção</p>
                    <div class="modal-close cursor-pointer z-50 text-gray-400 hover:text-white" onclick="toggleModal('categoriaModal')">
                        <i data-lucide="x"></i>
                    </div>
                </div>
                <form action="/{{ loja.slug_url }}/admin/categoria/salvar" method="POST" class="mt-4">
                    <input type="hidden" name="id" id="catId">
                    <div class="mb-4">
                        <label class="block text-sm font-bold mb-2 text-gray-300">Nome da Seção (Ex: hero, portfolio)</label>
                        <input type="text" name="nome" id="catNome" class="w-full bg-neutral-800 border border-neutral-700 rounded p-2 text-white focus:border-yellow-500 outline-none" required>
                    </div>
                    <div class="flex justify-end pt-2 gap-2">
                        <button type="button" class="px-4 bg-transparent p-2 rounded text-gray-400 hover:text-white" onclick="toggleModal('categoriaModal')">Cancelar</button>
                        <button type="submit" class="px-4 bg-yellow-500 p-2 rounded text-black font-bold hover:bg-yellow-600">Salvar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="produtoModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50 md:py-6">
        <div class="modal-overlay absolute w-full h-full bg-black opacity-80"></div>
        <div class="modal-container bg-neutral-900 border border-neutral-700 w-full h-full md:h-auto md:w-11/12 md:max-w-3xl mx-auto rounded shadow-2xl z-50 overflow-y-auto md:max-h-[90vh]">
            <div class="modal-content py-6 text-left px-6 md:px-8">
                <div class="flex justify-between items-center pb-6 border-b border-neutral-800">
                    <p class="text-2xl font-bold text-white" id="prodModalTitle">Novo Vídeo / Projeto</p>
                    <div class="modal-close cursor-pointer z-50 text-gray-400 hover:text-white" onclick="toggleModal('produtoModal')">
                        <i data-lucide="x"></i>
                    </div>
                </div>
                <form id="produtoForm" action="/{{ loja.slug_url }}/admin/produto/salvar" method="POST" enctype="multipart/form-data" class="mt-6 space-y-6">
                    <input type="hidden" name="id" id="prodId">
                    <input type="hidden" name="preco" value="0">
                    <input type="hidden" name="variantes" value="[]">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-bold mb-2 text-gray-300">Título do Projeto</label>
                            <input type="text" name="nome" id="prodNome" class="w-full bg-neutral-800 border border-neutral-700 rounded p-3 text-white focus:border-yellow-500 outline-none" required>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-300">Seção (Onde aparece)</label>
                            <select name="categoria_id" id="prodCategoria" class="w-full bg-neutral-800 border border-neutral-700 rounded p-3 text-white focus:border-yellow-500 outline-none">
                                <option value="">Sem Seção</option>
                                {% for cat in categorias %}
                                <option value="{{ cat.id }}">{{ cat.nome }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-bold mb-2 text-gray-300">Ano de Lançamento</label>
                            <input type="text" name="estoque" id="prodEstoque" class="w-full bg-neutral-800 border border-neutral-700 rounded p-3 text-white focus:border-yellow-500 outline-none" placeholder="Ex: 2026">
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm font-bold mb-2 text-gray-300">Subtítulo / Estilo (Aparece no Portfólio)</label>
                            <input type="text" name="descricao" id="prodDescricao" class="w-full bg-neutral-800 border border-neutral-700 rounded p-3 text-white focus:border-yellow-500 outline-none" placeholder="Ex: Film / Motion | Monaco">
                        </div>

                        <div class="md:col-span-2 bg-neutral-800 p-4 rounded border border-neutral-700">
                            <h4 class="font-bold text-yellow-400 text-sm mb-3">Integração Vimeo</h4>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-bold mb-1 text-gray-400">Link MP4 Direto (Fundo / Loop)</label>
                                    <input type="text" name="link_projeto" id="prodLinkProjeto" class="w-full bg-neutral-900 border border-neutral-700 rounded p-2 text-white focus:border-yellow-500 outline-none">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold mb-1 text-gray-400">Link Vimeo Player (Abre no clique)</label>
                                    <input type="text" name="whatsapp_projeto" id="prodWhatsappProjeto" class="w-full bg-neutral-900 border border-neutral-700 rounded p-2 text-white focus:border-yellow-500 outline-none" placeholder="Ex: https://player.vimeo.com/video/ID">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end pt-6 border-t border-neutral-800 gap-3 pb-20 md:pb-0">
                        <button type="button" class="px-6 py-3 rounded text-gray-400 hover:text-white" onclick="toggleModal('produtoModal')">Cancelar</button>
                        <button type="submit" class="px-8 py-3 rounded text-black bg-yellow-500 hover:bg-yellow-600 font-bold flex items-center gap-2">Salvar Projeto</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="postModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
        <div class="modal-overlay absolute w-full h-full bg-black opacity-80"></div>
        <div class="modal-container bg-neutral-900 border border-neutral-700 w-11/12 md:max-w-2xl mx-auto rounded shadow-lg z-50 overflow-y-auto">
            <div class="modal-content py-6 text-left px-8">
                <div class="flex justify-between items-center pb-6 border-b border-neutral-800">
                    <p class="text-2xl font-bold text-white" id="postModalTitle">Novo Serviço</p>
                    <div class="modal-close cursor-pointer z-50 text-gray-400 hover:text-white" onclick="toggleModal('postModal')">
                        <i data-lucide="x"></i>
                    </div>
                </div>
                <form id="postForm" action="/{{ loja.slug_url }}/admin/post/salvar" method="POST" enctype="multipart/form-data" class="mt-6 space-y-6">
                    <input type="hidden" name="id" id="postId">
                    
                    <div>
                        <label class="block text-sm font-bold mb-2 text-gray-300">Nome do Serviço</label>
                        <input type="text" name="titulo" id="postTitulo" class="w-full bg-neutral-800 border border-neutral-700 rounded p-3 text-white focus:border-yellow-500 outline-none" required>
                    </div>

                    <div>
                        <label class="block text-sm font-bold mb-2 text-gray-300">Ícone / Imagem</label>
                        <input type="file" name="capa" accept="image/*" class="w-full text-sm text-gray-400">
                    </div>

                    <div>
                        <label class="block text-sm font-bold mb-2 text-gray-300">Descrição</label>
                        <textarea name="resumo" id="postResumo" rows="4" class="w-full bg-neutral-800 border border-neutral-700 rounded p-3 text-white focus:border-yellow-500 outline-none"></textarea>
                    </div>

                    <div class="flex justify-end pt-6 border-t border-neutral-800 gap-3">
                        <button type="button" class="px-6 py-3 rounded text-gray-400 hover:text-white" onclick="toggleModal('postModal')">Cancelar</button>
                        <button type="submit" class="px-8 py-3 rounded text-black bg-yellow-500 hover:bg-yellow-600 font-bold">Salvar Serviço</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                const alerts = document.querySelectorAll('.flash-message-item');
                alerts.forEach(alert => {
                    alert.style.transition = "opacity 0.5s ease";
                    alert.style.opacity = "0";
                    setTimeout(() => alert.remove(), 500);
                });
            }, 4000);
        });

        function showSection(sectionId) {
            document.querySelectorAll('main > section, main > form > section').forEach(el => el.classList.add('hidden'));
            const target = document.getElementById(sectionId);
            if(target) target.classList.remove('hidden');
            
            document.querySelectorAll('aside nav a').forEach(el => {
                el.classList.remove('bg-neutral-800', 'text-yellow-400');
                if(el.getAttribute('href') === '#' + sectionId) {
                    el.classList.add('bg-neutral-800', 'text-yellow-400');
                }
            });

            localStorage.setItem('activePainelCreapesTab', sectionId);
            window.history.replaceState(null, null, '#' + sectionId);
        }

        function selectMenuItem(sectionId) {
            showSection(sectionId);
            if(window.innerWidth < 768) toggleMobileMenu();
        }

        function toggleMobileMenu() {
            const nav = document.getElementById('sidebarNav');
            const chevron = document.getElementById('menuChevron');
            if (nav.classList.contains('hidden')) {
                nav.classList.remove('hidden');
                nav.classList.add('mobile-nav-visible');
                chevron.style.transform = 'rotate(180deg)';
            } else {
                nav.classList.add('hidden');
                nav.classList.remove('mobile-nav-visible');
                chevron.style.transform = 'rotate(0deg)';
            }
        }

        const hash = window.location.hash.replace('#', '');
        const savedTab = localStorage.getItem('activePainelCreapesTab');
        showSection(hash || savedTab || 'categorias');

        function toggleModal(modalID) {
            document.getElementById(modalID).classList.toggle('opacity-0');
            document.getElementById(modalID).classList.toggle('pointer-events-none');
            document.body.classList.toggle('modal-active');
        }

        // CATEGORIAS
        function novaCategoria() {
            document.getElementById('catId').value = '';
            document.getElementById('catNome').value = '';
            document.getElementById('catModalTitle').innerText = 'Nova Seção';
            toggleModal('categoriaModal');
        }
        function editarCategoria(cat) {
            document.getElementById('catId').value = cat.id;
            document.getElementById('catNome').value = cat.nome;
            document.getElementById('catModalTitle').innerText = 'Editar Seção';
            toggleModal('categoriaModal');
        }

        // PRODUTOS (VIDEOS)
        function novoProduto() {
            document.getElementById('prodId').value = '';
            document.getElementById('prodNome').value = '';
            document.getElementById('prodCategoria').value = '';
            document.getElementById('prodEstoque').value = '';
            document.getElementById('prodDescricao').value = '';
            document.getElementById('prodLinkProjeto').value = '';
            document.getElementById('prodWhatsappProjeto').value = '';
            document.getElementById('prodModalTitle').innerText = 'Novo Projeto / Vídeo';
            toggleModal('produtoModal');
        }
        
        function editarProduto(prod) {
            document.getElementById('prodId').value = prod.id;
            document.getElementById('prodNome').value = prod.nome;
            document.getElementById('prodCategoria').value = prod.categoria_id || '';
            document.getElementById('prodEstoque').value = prod.estoque || '';
            document.getElementById('prodDescricao').value = prod.descricao || '';
            document.getElementById('prodLinkProjeto').value = prod.link_projeto || '';
            document.getElementById('prodWhatsappProjeto').value = prod.whatsapp_projeto || '';
            document.getElementById('prodModalTitle').innerText = 'Editar Projeto / Vídeo';
            toggleModal('produtoModal');
        }
        
        // POSTS (SERVIÇOS)
        function novoPost() {
            document.getElementById('postId').value = '';
            document.getElementById('postTitulo').value = '';
            document.getElementById('postResumo').value = '';
            document.querySelector('#postForm input[name="capa"]').value = '';
            document.getElementById('postModalTitle').innerText = 'Novo Serviço';
            toggleModal('postModal');
        }
        function editarPost(post) {
            document.getElementById('postId').value = post.id;
            document.getElementById('postTitulo').value = post.titulo;
            document.getElementById('postResumo').value = post.resumo || '';
            document.querySelector('#postForm input[name="capa"]').value = '';
            document.getElementById('postModalTitle').innerText = 'Editar Serviço';
            toggleModal('postModal');
        }

        new Sortable(document.getElementById('lista-categorias'), {
            animation: 150,
            ghostClass: 'sortable-ghost',
            handle: '.cursor-move'
        });
    </script>
</body>
</html>
